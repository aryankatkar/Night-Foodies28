# Default: use JSON file to store customer data (signup info saved locally)
DB_DRIVER=file

# MySQL use karna ho to upar wali line ko `DB_DRIVER=mysql` karo
# aur neeche ke values apne server ke hisaab se bharo.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=night_foodies
