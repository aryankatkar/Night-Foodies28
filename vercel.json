{
  "version": 2,
  "name": "night-foodies",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:action(send-otp|verify-otp|login|signup)",
      "destination": "/api/auth/:action.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "env": {
    "DB_DRIVER": "memory",
    "VERCEL": "1"
  }
}
