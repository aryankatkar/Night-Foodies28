{
  "version": 2,
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/$1.js"
    },
    {
      "src": "/api/admin/products/delete",
      "dest": "/api/admin/products.js"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/admin/$1.js"
    },
    {
      "src": "/checkout",
      "dest": "/checkout.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/admin-login",
      "dest": "/admin-login.html"
    }
  ],
  "env": {
    "DB_DRIVER": "memory",
    "VERCEL": "1"
  }
}
